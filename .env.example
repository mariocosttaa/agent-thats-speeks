# Copy to .env at repo root. Never commit .env.

# Google AI Studio / Gemini API (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Docker Compose: host ports (optional)
# BACKEND_HOST_PORT=8000
# FRONTEND_HOST_PORT=3000

# URL the browser uses to reach the API (must match docker-compose port mapping).
# Rebuild `web` after changing this: docker compose build web --no-cache
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Optional: comma-separated CORS origins (must include your Next.js origin).
# If FRONTEND_HOST_PORT is not 3000, set e.g. CORS_ORIGINS=http://localhost:3001
# CORS_ORIGINS=http://localhost:3000

# Local dev without Docker: copy frontend/.env.example to frontend/.env.local
