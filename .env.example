# Backend: copy to .env at repo root (or backend/.env). Never commit .env.

# Google AI Studio / Gemini API (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Optional: comma-separated origins for CORS (default: http://localhost:3000)
# CORS_ORIGINS=http://localhost:3000,https://your-app.example

# Frontend: copy frontend/.env.example to frontend/.env.local
# (NEXT_PUBLIC_API_BASE_URL defaults to http://localhost:8000)
